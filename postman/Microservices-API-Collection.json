{
  "info": {
    "name": "Personal Microservices - Step-wise API Tests",
    "description": "Run requests top to bottom. Each step auto-saves IDs (userId, productId, orderId) as collection variables so the next step picks them up automatically.\n\nBase URL: http://localhost:8080 (API Gateway)\n\nStartup order before testing:\n1. PostgreSQL\n2. Eureka Server (port 8761)\n3. Config Server (port 8888)\n4. User Service, Product Service, Auth Service\n5. Order Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:8080", "type": "string" },
    { "key": "userId",     "value": "",                      "type": "string" },
    { "key": "productId",  "value": "",                      "type": "string" },
    { "key": "orderId",    "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "STEP 1 — Health Checks",
      "item": [
        {
          "name": "1.1 Eureka Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:8761", "protocol": "http", "host": ["localhost"], "port": "8761" }
          }
        },
        {
          "name": "1.2 Config Server Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:8888/actuator/health", "protocol": "http", "host": ["localhost"], "port": "8888", "path": ["actuator","health"] }
          }
        },
        {
          "name": "1.3 User Service Health (direct)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:8081/users", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["users"] }
          }
        },
        {
          "name": "1.4 Product Service Health (direct)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:8084/products", "protocol": "http", "host": ["localhost"], "port": "8084", "path": ["products"] }
          }
        },
        {
          "name": "1.5 Order Service Health (direct)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:8082/orders", "protocol": "http", "host": ["localhost"], "port": "8082", "path": ["orders"] }
          }
        }
      ]
    },

    {
      "name": "STEP 2 — User Service",
      "item": [

        {
          "name": "2.1 Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('userId', json.id);",
                  "    console.log('userId saved:', json.id);",
                  "    pm.test('User registered successfully', () => pm.expect(pm.response.code).to.eql(201));",
                  "    pm.test('Password NOT in response', () => pm.expect(json).to.not.have.property('password'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ashish\",\n  \"lastName\": \"Sharma\",\n  \"email\": \"ashish@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\",\n  \"role\": \"USER\",\n  \"address\": \"123 MG Road\",\n  \"city\": \"Bangalore\",\n  \"state\": \"Karnataka\",\n  \"pincode\": \"560001\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users","register"] }
          }
        },

        {
          "name": "2.2 Register Admin User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin registered', () => pm.expect(pm.response.code).to.eql(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"phone\": \"9000000000\",\n  \"role\": \"ADMIN\",\n  \"address\": \"Admin HQ\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\",\n  \"pincode\": \"400001\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users","register"] }
          }
        },

        {
          "name": "2.3 Get All Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },

        {
          "name": "2.4 Get User by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('ID matches', () => pm.expect(pm.response.json().id).to.eql(Number(pm.collectionVariables.get('userId'))));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] }
          }
        },

        {
          "name": "2.5 Get User by Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Email matches', () => pm.expect(pm.response.json().email).to.eql('ashish@example.com'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/email?email=ashish@example.com",
              "host": ["{{baseUrl}}"],
              "path": ["users","email"],
              "query": [{ "key": "email", "value": "ashish@example.com" }]
            }
          }
        },

        {
          "name": "2.6 Update User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('City updated', () => pm.expect(pm.response.json().city).to.eql('Pune'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ashish\",\n  \"lastName\": \"Sharma\",\n  \"phone\": \"9123456789\",\n  \"address\": \"456 FC Road\",\n  \"city\": \"Pune\",\n  \"state\": \"Maharashtra\",\n  \"pincode\": \"411001\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] }
          }
        },

        {
          "name": "2.7 Get User Not Found (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 404 for unknown user', () => pm.expect(pm.response.code).to.eql(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/99999", "host": ["{{baseUrl}}"], "path": ["users","99999"] }
          }
        }
      ]
    },

    {
