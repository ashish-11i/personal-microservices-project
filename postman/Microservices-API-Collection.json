{
  "info": {
    "name": "Personal Microservices - Step-wise API Tests",
    "description": "Run requests TOP TO BOTTOM in order.\n\nStep 1 checks health.\nStep 2 registers a user (public — no token needed).\nStep 3 logs in and auto-saves the Bearer token.\nAll steps from Step 4 onwards use the saved token automatically.\n\nCollection variables auto-chained:\n  {{token}}      — saved by Step 3.1 Login\n  {{userId}}     — saved by Step 2.1 Register User\n  {{productId}}  — saved by Step 4.1 Add Product\n  {{orderId}}    — saved by Step 5.1 Place Order\n\nBase URL: http://localhost:8080 (API Gateway)\n\nStartup order before testing:\n  1. PostgreSQL\n  2. Eureka Server     :8761\n  3. Config Server     :8888\n  4. Auth, User, Product Services\n  5. Order Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "http://localhost:8080", "type": "string" },
    { "key": "token",     "value": "",                      "type": "string" },
    { "key": "userId",    "value": "",                      "type": "string" },
    { "key": "productId", "value": "",                      "type": "string" },
    { "key": "orderId",   "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "STEP 1 — Health Checks",
      "item": [
        {
          "name": "1.1 Eureka Dashboard",
          "request": { "method": "GET", "header": [],
            "url": { "raw": "http://localhost:8761", "protocol": "http", "host": ["localhost"], "port": "8761" } }
        },
        {
          "name": "1.2 Config Server Health",
          "request": { "method": "GET", "header": [],
            "url": { "raw": "http://localhost:8888/actuator/health", "protocol": "http", "host": ["localhost"], "port": "8888", "path": ["actuator","health"] } }
        },
        {
          "name": "1.3 User Service (direct :8081)",
          "request": { "method": "GET", "header": [],
            "url": { "raw": "http://localhost:8081/users", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["users"] } }
        },
        {
          "name": "1.4 Product Service (direct :8084)",
          "request": { "method": "GET", "header": [],
            "url": { "raw": "http://localhost:8084/products", "protocol": "http", "host": ["localhost"], "port": "8084", "path": ["products"] } }
        },
        {
          "name": "1.5 Order Service (direct :8082)",
          "request": { "method": "GET", "header": [],
            "url": { "raw": "http://localhost:8082/orders", "protocol": "http", "host": ["localhost"], "port": "8082", "path": ["orders"] } }
        }
      ]
    },

    {
      "name": "STEP 2 — Register Users (public — no token needed)",
      "item": [
        {
          "name": "2.1 Register User",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 201) {",
              "    var json = pm.response.json();",
              "    pm.collectionVariables.set('userId', json.id);",
              "    console.log('userId saved:', json.id);",
              "    pm.test('User created (201)', () => pm.expect(pm.response.code).to.eql(201));",
              "    pm.test('Password NOT exposed', () => pm.expect(json).to.not.have.property('password'));",
              "}"
            ], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Ashish\",\n  \"lastName\": \"Sharma\",\n  \"email\": \"ashish@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\",\n  \"role\": \"USER\",\n  \"address\": \"123 MG Road\",\n  \"city\": \"Bangalore\",\n  \"state\": \"Karnataka\",\n  \"pincode\": \"560001\"\n}" },
            "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users","register"] }
          }
        },
        {
          "name": "2.2 Register Admin User",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Admin created (201)', () => pm.expect(pm.response.code).to.eql(201));"
            ], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"phone\": \"9000000000\",\n  \"role\": \"ADMIN\",\n  \"address\": \"Admin HQ\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\",\n  \"pincode\": \"400001\"\n}" },
            "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users","register"] }
          }
        },
        {
          "name": "2.3 Block internal endpoint (expect 403)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Internal endpoint blocked by gateway (403)', () => pm.expect(pm.response.code).to.eql(403));"
            ], "type": "text/javascript" }
          }],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/users/internal/email?email=ashish@example.com", "host": ["{{baseUrl}}"], "path": ["users","internal","email"], "query": [{ "key": "email", "value": "ashish@example.com" }] }
          }
        }
      ]
    },

    {
      "name": "STEP 3 — Auth (Login & get token)",
      "item": [
        {
          "name": "3.1 Login as User ✦ (saves token)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Login successful (200)', () => pm.expect(pm.response.code).to.eql(200));",
              "var json = pm.response.json();",
              "pm.test('Token returned', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
              "pm.collectionVariables.set('token', json.token);",
              "console.log('Bearer token saved');"
            ], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"ashish@example.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "3.2 Login with wrong password (expect 401/403)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Bad credentials rejected', () => pm.expect(pm.response.code).to.be.oneOf([401, 403, 500]));"
            ], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"ashish@example.com\",\n  \"password\": \"wrongpassword\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "3.3 Access protected route without token (expect 401)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('No token = 401', () => pm.expect(pm.response.code).to.eql(401));"
            ], "type": "text/javascript" }
          }],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        }
      ]
    },

    {
      "name": "STEP 4 — User Service (authenticated)",
      "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
      "item": [
        {
          "name": "4.1 Get All Users",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] } }
        },
        {
          "name": "4.2 Get User by ID",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('ID matches', () => pm.expect(pm.response.json().id).to.eql(Number(pm.collectionVariables.get('userId'))));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] } }
        },
        {
          "name": "4.3 Get User by Email",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('Email matches', () => pm.expect(pm.response.json().email).to.eql('ashish@example.com'));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/users/email?email=ashish@example.com", "host": ["{{baseUrl}}"], "path": ["users","email"], "query": [{ "key": "email", "value": "ashish@example.com" }] } }
        },
        {
          "name": "4.4 Update User",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('City updated', () => pm.expect(pm.response.json().city).to.eql('Pune'));"
            ], "type": "text/javascript" }
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Ashish\",\n  \"lastName\": \"Sharma\",\n  \"phone\": \"9123456789\",\n  \"address\": \"456 FC Road\",\n  \"city\": \"Pune\",\n  \"state\": \"Maharashtra\",\n  \"pincode\": \"411001\"\n}" },
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] }
          }
        },
        {
          "name": "4.5 Get User Not Found (expect 404)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('404 for unknown user', () => pm.expect(pm.response.code).to.eql(404));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/users/99999", "host": ["{{baseUrl}}"], "path": ["users","99999"] } }
        }
      ]
    },

    {
      "name": "STEP 5 — Product Service (authenticated)",
      "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
      "item": [
        {
          "name": "5.1 Add Product (Laptop) ✦ saves productId",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 201) {",
              "    var json = pm.response.json();",
              "    pm.collectionVariables.set('productId', json.id);",
              "    console.log('productId saved:', json.id);",
              "    pm.test('Product created (201)', () => pm.expect(pm.response.code).to.eql(201));",
              "    pm.test('isAvailable true', () => pm.expect(json.available).to.eql(true));",
              "}"
            ], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"MacBook Pro M3\",\n  \"description\": \"Apple MacBook Pro with M3 chip, 16GB RAM, 512GB SSD\",\n  \"price\": 149999.99,\n  \"stock\": 50,\n  \"category\": \"Laptops\",\n  \"brand\": \"Apple\",\n  \"imageUrl\": \"https://example.com/macbook-pro.jpg\"\n}" },
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
          }
        },
        {
          "name": "5.2 Add Product (Phone)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"iPhone 15 Pro\",\n  \"description\": \"Apple iPhone 15 Pro, 256GB, Titanium\",\n  \"price\": 134999.00,\n  \"stock\": 100,\n  \"category\": \"Smartphones\",\n  \"brand\": \"Apple\",\n  \"imageUrl\": \"https://example.com/iphone15.jpg\"\n}" },
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
          }
        },
        {
          "name": "5.3 Get All Products",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('Has products', () => pm.expect(pm.response.json().length).to.be.greaterThan(0));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] } }
        },
        {
          "name": "5.4 Get Product by ID",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] } }
        },
        {
          "name": "5.5 Update Product",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('Price updated', () => pm.expect(pm.response.json().price).to.eql(139999.99));"
            ], "type": "text/javascript" }
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"MacBook Pro M3\",\n  \"description\": \"Updated — Apple MacBook Pro M3, 16GB, 512GB SSD\",\n  \"price\": 139999.99,\n  \"stock\": 50,\n  \"category\": \"Laptops\",\n  \"brand\": \"Apple\",\n  \"imageUrl\": \"https://example.com/macbook-v2.jpg\",\n  \"available\": true\n}" },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] }
          }
        },
        {
          "name": "5.6 Product Not Found (expect 404)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('404 for unknown product', () => pm.expect(pm.response.code).to.eql(404));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/products/99999", "host": ["{{baseUrl}}"], "path": ["products","99999"] } }
        }
      ]
    },

    {
      "name": "STEP 6 — Order Service — Inter-Service Communication",
      "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
      "item": [
        {
          "name": "6.1 Place Order ✦ (user-service + product-service called internally)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 201) {",
              "    var json = pm.response.json();",
              "    pm.collectionVariables.set('orderId', json.id);",
              "    console.log('orderId saved:', json.id);",
              "    pm.test('Order created (201)', () => pm.expect(pm.response.code).to.eql(201));",
              "    pm.test('Status is CREATED', () => pm.expect(json.status).to.eql('CREATED'));",
              "    pm.test('totalPrice > 0', () => pm.expect(json.totalPrice).to.be.greaterThan(0));",
              "    pm.test('address saved', () => pm.expect(json.address).to.not.be.empty);",
              "}"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "POST", "header": [],
            "url": { "raw": "{{baseUrl}}/orders?userId={{userId}}&productId={{productId}}&quantity=2&address=456 FC Road, Pune 411001",
              "host": ["{{baseUrl}}"], "path": ["orders"],
              "query": [
                { "key": "userId",    "value": "{{userId}}" },
                { "key": "productId", "value": "{{productId}}" },
                { "key": "quantity",  "value": "2" },
                { "key": "address",   "value": "456 FC Road, Pune 411001" }
              ]
            }
          }
        },
        {
          "name": "6.2 Verify stock reduced in product-service",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "var json = pm.response.json();",
              "console.log('Stock after order:', json.stock);",
              "pm.test('Stock reduced by 2 (50 - 2 = 48)', () => pm.expect(json.stock).to.eql(48));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] } }
        },
        {
          "name": "6.3 Place Order — insufficient stock (expect 400)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('400 for insufficient stock', () => pm.expect(pm.response.code).to.eql(400));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "POST", "header": [],
            "url": { "raw": "{{baseUrl}}/orders?userId={{userId}}&productId={{productId}}&quantity=9999&address=Test",
              "host": ["{{baseUrl}}"], "path": ["orders"],
              "query": [
                { "key": "userId",    "value": "{{userId}}" },
                { "key": "productId", "value": "{{productId}}" },
                { "key": "quantity",  "value": "9999" },
                { "key": "address",   "value": "Test" }
              ]
            }
          }
        },
        {
          "name": "6.4 Place Order — invalid user (expect 4xx)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Error for unknown user', () => pm.expect(pm.response.code).to.be.oneOf([400, 404, 500]));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "POST", "header": [],
            "url": { "raw": "{{baseUrl}}/orders?userId=99999&productId={{productId}}&quantity=1&address=Test",
              "host": ["{{baseUrl}}"], "path": ["orders"],
              "query": [
                { "key": "userId",    "value": "99999" },
                { "key": "productId", "value": "{{productId}}" },
                { "key": "quantity",  "value": "1" },
                { "key": "address",   "value": "Test" }
              ]
            }
          }
        },
        {
          "name": "6.5 Get All Orders",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] } }
        },
        {
          "name": "6.6 Get Order by ID",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('ID matches', () => pm.expect(pm.response.json().id).to.eql(Number(pm.collectionVariables.get('orderId'))));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["orders","{{orderId}}"] } }
        },
        {
          "name": "6.7 Get Orders by User",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('All orders belong to this user', () => {",
              "    pm.response.json().forEach(o => pm.expect(o.userId).to.eql(Number(pm.collectionVariables.get('userId'))));",
              "});"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/orders/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["orders","user","{{userId}}"] } }
        },
        {
          "name": "6.8 Update Status → PAID",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('order status = PAID', () => pm.expect(pm.response.json().status).to.eql('PAID'));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "PUT", "header": [],
            "url": { "raw": "{{baseUrl}}/orders/{{orderId}}/status?status=PAID",
              "host": ["{{baseUrl}}"], "path": ["orders","{{orderId}}","status"],
              "query": [{ "key": "status", "value": "PAID" }] } }
        },
        {
          "name": "6.9 Update Status → SHIPPED",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('order status = SHIPPED', () => pm.expect(pm.response.json().status).to.eql('SHIPPED'));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "PUT", "header": [],
            "url": { "raw": "{{baseUrl}}/orders/{{orderId}}/status?status=SHIPPED",
              "host": ["{{baseUrl}}"], "path": ["orders","{{orderId}}","status"],
              "query": [{ "key": "status", "value": "SHIPPED" }] } }
        },
        {
          "name": "6.10 Update Status → DELIVERED",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
              "pm.test('order status = DELIVERED', () => pm.expect(pm.response.json().status).to.eql('DELIVERED'));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "PUT", "header": [],
            "url": { "raw": "{{baseUrl}}/orders/{{orderId}}/status?status=DELIVERED",
              "host": ["{{baseUrl}}"], "path": ["orders","{{orderId}}","status"],
              "query": [{ "key": "status", "value": "DELIVERED" }] } }
        },
        {
          "name": "6.11 Order Not Found (expect 404)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('404 for unknown order', () => pm.expect(pm.response.code).to.eql(404));"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/orders/99999", "host": ["{{baseUrl}}"], "path": ["orders","99999"] } }
        }
      ]
    },

    {
      "name": "STEP 7 — Cleanup (optional)",
