    {
      "name": "STEP 4 — Order Service (Inter-Service Communication)",
      "item": [

        {
          "name": "4.1 Place Order ✦ (calls user-service + product-service)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('orderId', json.id);",
                  "    console.log('orderId saved:', json.id);",
                  "    pm.test('Order created', () => pm.expect(pm.response.code).to.eql(201));",
                  "    pm.test('Status is CREATED', () => pm.expect(json.status).to.eql('CREATED'));",
                  "    pm.test('totalPrice calculated', () => pm.expect(json.totalPrice).to.be.greaterThan(0));",
                  "    pm.test('Address saved', () => pm.expect(json.address).to.not.be.empty);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders?userId={{userId}}&productId={{productId}}&quantity=2&address=456 FC Road, Pune 411001",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "userId",    "value": "{{userId}}" },
                { "key": "productId", "value": "{{productId}}" },
                { "key": "quantity",  "value": "2" },
                { "key": "address",   "value": "456 FC Road, Pune 411001" }
              ]
            }
          }
        },

        {
          "name": "4.2 Verify Stock Reduced (check product after order)",
