                  "var json = pm.response.json();",
                  "console.log('Stock after order:', json.stock);",
                  "pm.test('Stock reduced by 2', () => pm.expect(json.stock).to.eql(48));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] }
          }
